[Unit]
Description=Personal Website
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/yulei/code/personal-website
Environment="PATH=/root/yulei/code/personal-website/venv/bin"
ExecStart=/root/yulei/code/personal-website/venv/bin/gunicorn -w 4 -b 0.0.0.0:80 app:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
